# /etc/wan-failover/mail.env
# SMTP settings for wan-failover email alerts.
# chmod 600 this file after editing — it contains a password.

MAIL_ENABLED=true

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS="example"

MAIL_FROM=noreply@example.in

# The inbox that should actually receive switch-alert emails
MAIL_TO=you@yourdomain.com

# Optional: shown as an "Open Dashboard" button in alert emails.
# Leave blank to omit the button entirely.
DASHBOARD_URL=https://wan.yourdomain.com
