[Unit]
Description=Multi-WAN active/backup failover (eno4 primary)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/wan-failover.sh
EnvironmentFile=-/etc/wan-failover/mail.env
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
